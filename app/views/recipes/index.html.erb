<div class="container-fluid mt-4">
  <div class="row">

    <% if @ai_response.present? %>
      <div class="mt-4 p-4" style="background: #f5f5f5; border-radius: 12px;">
        <%= sanitize(Redcarpet::Markdown.new(Redcarpet::Render::HTML).render(@ai_response)) %>
      </div>
    <% end %>

    <%# Colonne gauche : liste des recettes %>
    <div class="col-3 border-end">
      <h6 class="fw-bold">Retrieve your favorites recipes</h6>

      <ul class="list-unstyled mt-3">
        <% @recipes.each do |recipe| %>
          <li class="mb-2">
            <%= link_to recipe.title, recipe_path(recipe) %>
          </li>
        <% end %>
      </ul>
    </div>

  <%# Colonne droite : chat IA %>
  <div class="col-9">
    <% @chat = current_user.chats.last %>
    <% if @chat %>
      <h6 class="fw-bold">Chat with AI</h6>

      <div id="messages" data-controller="scroll" style="height: 60vh; overflow-y: auto;">
        <%= render "messages/messages", messages: @chat.messages %>
      </div>

      <div id="new_message_container">
        <%= render "messages/form", chat: @chat, message: Message.new %>
      </div>
    <% end %>
  </div>
</div>
