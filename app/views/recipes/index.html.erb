<div class="container-fluid mt-4">
  <div class="row">

    <!-- Colonne gauche : liste des recettes -->
    <div class="col-3 border-end">
      <h6 class="fw-bold">Retrieve your favorites recipes</h6>

      <ul class="list-unstyled mt-3">
        <% @recipes.each do |recipe| %>
          <li class="mb-2">
            • <%= link_to recipe.title, recipe_path(recipe) %>
            <%= button_to "Delete", recipe_path(recipe), method: :delete, class: "btn btn-danger btn-sm", data: { confirm: "Are you sure?" } %>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Colonne droite : réservée au chat IA -->
    <div class="col-9">
    </div>

  </div>
</div>
