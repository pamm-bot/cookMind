<div class="text-center py-5">

  <h1 class="display-4 fw-500 mb-3">Welcome 👋</h1>
  <p class="lead text-muted mb-4">
    Smart recipes. Personalized for you.
  </p>

  <div class="d-flex justify-content-center gap-3 mb-4">
    <%= link_to profil_path(current_user.profil), class: "btn btn-cook-yellow btn-lg d-flex align-items-center gap-2 px-4" do %>
      <i class="bi bi-person-circle fs-4"></i>
      Preferences
    <% end %>

    <%= link_to "Ingredients", ingredients_path, class: "btn btn-cook-yellow btn-lg d-flex align-items-center gap-2 px-4" %>
  </div>

</div>

<div class="container py-4">
  <div class="row justify-content-center g-4">

    <div class="col-md-3">
      <div class="card card-lavender text-center p-4 h-100">
        <div class="step-number mx-auto mb-3">1</div>
        <h5 class="fw-500">Add your dietary preferences and ingredients</h5>
        <p class="text-muted small">Tell us what you have and what you like</p>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card card-yellow text-center p-4 h-100">
        <div class="step-number mx-auto mb-3">2</div>
        <h5 class="fw-500">Ask the AI</h5>
        <p class="text-muted small">Get personalized recipe suggestions</p>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card card-lavender text-center p-4 h-100">
        <div class="step-number mx-auto mb-3">3</div>
        <h5 class="fw-500">Cook & enjoy</h5>
        <p class="text-muted small">Follow the steps and save your favorites</p>
      </div>
    </div>

  </div>
</div>
