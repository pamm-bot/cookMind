<div class="text-center py-5 home-wrapper">
  <div class="home-content">
    <h1 class="home-title">Welcome 👋</h1>
    <p class="home-subtitle">Tell us what's in your fridge — we'll suggest the perfect recipe!</p>

    <% if user_signed_in? %>
      <div class="d-flex justify-content-center gap-2">
        <%= link_to "Preferences", edit_profil_path(current_user.profil || current_user), class: "btn-home-action btn-lg" %>
        <%= link_to "Ingredients", ingredients_path, class: "btn-home-action btn-lg" %>
      </div>
    <% else %>
      <div class="d-flex justify-content-center gap-2">
        <%= link_to "Ingredients", ingredients_path, class: "btn-home-action btn-lg" %>
      </div>
    <% end %>
  </div>
</div>

<div class="container py-4">
  <div class="steps-row">
    <div class="step-card">
      <div class="card card-lavender text-center p-4 h-100">
        <div class="step-number mb-3">1</div>
        <h5 class="fw-500">Ingredients & Preferences</h5>
        <p class="text-muted small">Enter your dietary preferences and the ingredients you have at home</p>
        <% if user_signed_in? && current_user.profil&.dietary_preferences.present? %>
          <p class="mt-2 mb-0" style="font-size:13px;color:#6B6459;">
            Preferences: <strong><%= current_user.profil.dietary_preferences %></strong>
          </p>
        <% end %>
      </div>
    </div>

    <div class="step-card">
      <div class="card card-yellow text-center p-4 h-100">
        <div class="step-number mb-3">2</div>
        <h5 class="fw-500">Ask the AI</h5>
        <p class="text-muted small">Get personalized recipe suggestions</p>
      </div>
    </div>

    <div class="step-card">
      <div class="card card-lavender text-center p-4 h-100">
        <div class="step-number mb-3">3</div>
        <h5 class="fw-500">Cook & enjoy</h5>
        <p class="text-muted small">Follow the steps and save your favorites</p>
      </div>
    </div>
  </div>
</div>
