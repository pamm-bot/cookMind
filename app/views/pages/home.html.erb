<div class="home-container">

  <!-- HEADER -->
  <header class="home-header">
    <nav class="home-nav">
      <%= link_to "Accueil", root_path %>
      <%= link_to "cookMind AI", chats_path %>
      <%= link_to "My Recipes", recipes_path %>
      <%= link_to "My profil", profil_path(current_user.profil) if current_user.profil.present? %>
      <span class="home-user-icon">👤</span>
    </nav>
  </header>

  <!-- MAIN CONTENT -->
  <main class="home-main">
    <h1>Welcome 👋</h1>
    <p class="subtitle">What are we going to cook today?</p>

    <%= link_to "+ Add a new ingredient", new_ingredient_path, class: "btn-add-ingredient" %>

    <div class="ingredients-box">
      <h3>Your ingredients</h3>

      <% if @ingredients.present? %>
        <ul>
          <% @ingredients.each do |ingredient| %>
            <li><%= ingredient.name.capitalize %></li>
          <% end %>
        </ul>
      <% else %>
        <p class="empty">No ingredients yet.</p>
      <% end %>
    </div>

    <%= link_to "Submit", recipes_path, class: "btn-submit" %>
  </main>

</div>
