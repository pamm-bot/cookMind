<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-5">

      <div class="card" style="border-radius: 16px; border: 0.5px solid #e3e7e5; overflow: hidden;">

        <%# Bannière violette %>
        <div style="background-color: #7C6FAB; height: 70px; display: flex; align-items: center; justify-content: center;">
          <h5 class="text-white mb-0">Edit my profile</h5>
        </div>

        <div class="p-4">

          <%= form_with model: @profil, url: profil_path(@profil), method: :patch, html: { multipart: true } do |f| %>

            <%# Photo de profil %>
            <div class="text-center mb-4">
              <% if @profil.avatar.attached? %>
                <%= image_tag @profil.avatar, class: "rounded-circle mb-2", style: "width: 80px; height: 80px; object-fit: cover; border: 3px solid #7C6FAB;" %>
              <% else %>
                <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center mb-2" style="width: 80px; height: 80px; background-color: #FACC15; font-size: 2rem;">
                  🧑‍🍳
                </div>
              <% end %>
              <%= f.label :avatar, "Change photo", class: "d-block text-muted mb-2", style: "font-size: 12px;" %>
              <%= f.file_field :avatar, class: "form-control form-control-sm" %>
            </div>

            <%# Préférences alimentaires %>
            <div class="mb-4">
              <%= f.label :dietary_preferences, "🥗 Dietary preferences", class: "fw-bold mb-2", style: "font-size: 13px;" %>
              <%= f.text_field :dietary_preferences, class: "form-control", placeholder: "Ex: vegetarian, gluten-free, halal...", style: "border-radius: 8px;" %>
            </div>

            <%# Boutons %>
            <%= f.submit "Save", class: "btn w-100 fw-500 mb-2", style: "background-color: #FACC15; color: #1A1A1A; border-radius: 8px;" %>
            <%= link_to "Cancel", profil_path(@profil), class: "btn w-100", style: "border: 1px solid #7C6FAB; color: #7C6FAB; border-radius: 8px;" %>

          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>
