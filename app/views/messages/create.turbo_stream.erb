<%# Met à jour le titre si il a changé %>
<% if @chat.title_previously_changed? %>
  <%= turbo_stream.update "chat_title", @chat.title %>
<% end %>

<%= turbo_stream.append "messages" do %>
  <%# ajoute les nouveaux messages dans la div #messages sans recharger %>
  <%= render "messages/message", message: @message %>
  <%= render "messages/message", message: @assistant_message %>
<% end %>

<%= turbo_stream.update "new_message_container" do %>
  <%# remet le formulaire à vide après l'envoi %>
  <%= render "messages/form", chat: @chat, message: Message.new %>
<% end %>
