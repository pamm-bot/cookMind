<h1>Your Ingredients</h1>

<!-- Form to add a new ingredient -->
<%= form_with url: ingredients_path, method: :post, local: true do %>
  <div>
    <%= label_tag :ingredient, "New ingredient" %>
    <%= text_field_tag :ingredient %>
    <%= submit_tag "Add" %>
  </div>
<% end %>

<hr>

<!-- List of ingredients -->
<% @ingredients.each_with_index do |ingredient, index| %>
  <p>
    <%= ingredient %>

    <%= link_to "Delete",
        ingredient_path(index),
        method: :delete,
        data: { confirm: "Are you sure you want to delete this ingredient?" } %>
  </p>
<% end %>
