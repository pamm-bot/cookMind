<div class="container mt-4 ingredients-page">

  <div class="text-center mb-4">
    <div class="ingredients-icon-badge mx-auto mb-3">🥑</div>
    <h1 class="fw-500">What's in your fridge?</h1>
    <p class="text-muted">Add your ingredients and let the AI suggest a recipe</p>
  </div>

  <div class="ingredient-input-bar mb-4">
    <%= simple_form_for :ingredient, url: ingredients_path, method: :post do |f| %>

      <%= f.input :ingredient,
        label: "Add a new ingredient",
        placeholder: "Tomato, basil, pasta...",
        required: false,
        input_html: {
          class: "form-control",
          style: "border-radius:8px; border:1px solid #006d77; padding:8px; font-size:0.9rem;",
          onfocus: "this.placeholder=''",
          onblur: "this.placeholder='Tomato, basil, pasta...'"
        },
        label_html: { style: "color:#006d77; font-size:0.9rem; font-weight:500;" }
      %>

      <%= f.button :submit, "+ Add", class: "btn btn-cook-yellow-pill" %>

    <% end %>
  </div>

  <% @ingredients.each_with_index do |ingredient, index| %>
    <div class="d-flex justify-content-between align-items-center p-2 mb-2 rounded"
         style="background:white; border:1px solid #e3e7e5; border-radius:8px;">
      <span style="font-size:0.95rem; color:#006d77;"><%= ingredient %></span>

      <%= link_to "Delete",
        ingredient_path(index),
        data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this ingredient?" },
        class: "btn btn-sm",
        style: "background:#006d77; color:white; border-radius:6px; font-size:0.8rem;" %>
    </div>
  <% end %>

  <% if @ingredients.present? %>
    <div class="ingredients-card mb-4">
      <p class="ingredients-label">Current ingredients</p>

      <% @ingredients.each_with_index do |ingredient, index| %>
        <div class="d-flex justify-content-between align-items-center">
          <span class="ingredient-text"><%= ingredient %></span>

          <%= link_to "×",
            ingredient_path(index),
            data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this ingredient?" },
            class: "ingredient-delete" %>
        </div>
      <% end %>
    </div>

    <div class="text-center">
      <%= link_to "Find recipes with AI",
        recipes_path(ingredients: @ingredients),
        class: "btn btn-cook-purple-solid" %>
    </div>
  <% end %>

</div>
