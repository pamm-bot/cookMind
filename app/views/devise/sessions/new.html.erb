<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-5">

      <div class="auth-card">

        <div class="text-center mb-4">
          <div style="width: 56px; height: 56px; border-radius: 18px; background: #D6D3F0; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; font-size: 26px;">
            🍴
          </div>
          <p style="font-size: 20px; font-weight: 500; color: #4A4640; margin: 0 0 4px;">Welcome back</p>
          <p style="font-size: 13px; color: #9C9488; margin: 0;">Log in to continue cooking</p>
        </div>

        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="form-inputs mb-3">
            <%= f.input :email,
                        required: false,
                        autofocus: true,
                        input_html: { autocomplete: "email", style: "border-radius: 10px; border: 1px solid #EDEAE2; padding: 10px 14px;" },
                        label_html: { style: "font-size: 13px; color: #6B6459;" } %>
            <%= f.input :password,
                        required: false,
                        input_html: { autocomplete: "current-password", style: "border-radius: 10px; border: 1px solid #EDEAE2; padding: 10px 14px;" },
                        label_html: { style: "font-size: 13px; color: #6B6459;" } %>
            <%= f.input :remember_me, as: :boolean, label_html: { style: "font-size: 13px; color: #9C9488;" } if devise_mapping.rememberable? %>
          </div>

          <div class="form-actions">
            <%= f.button :submit, "Log in", class: "w-100", style: "background-color: #D6D3F0; color: #4F4880; border: none; border-radius: 20px; padding: 12px; font-weight: 500;" %>
          </div>
        <% end %>

        <div class="text-center mt-3" style="font-size: 13px;">
          <%= render "devise/shared/links" %>
        </div>

      </div>
    </div>
  </div>
</div>
