<nav class="navbar navbar-expand-sm navbar-cookmind">
  <div class="container-fluid">
    <%= link_to root_path, class: "navbar-brand" do %>
      CookMind 🍴
    <% end %>

    <% if user_signed_in? %>
      <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link d-md-none" %>
    <% end %>

    <div class="collapse navbar-collapse d-none d-md-block" id="navbarSupportedContent">
      <ul class="navbar-nav ms-auto">
        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to "Ingredients", ingredients_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Recipes", recipes_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Chats", chats_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Profile", profil_path(current_user.profil || current_user.create_profil(dietary_preferences: "")), class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Login", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign up", new_user_registration_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>

<nav class="mobile-bottom-nav d-md-none">
  <% if user_signed_in? %>

    <%= link_to ingredients_path, class: "mobile-nav-item #{'active' if current_page?(ingredients_path)}" do %>
      <i class="fa-solid fa-carrot"></i>
      <span>Ingredients</span>
    <% end %>
    <%= link_to recipes_path, class: "mobile-nav-item #{'active' if current_page?(recipes_path)}" do %>
      <i class="fa-solid fa-utensils"></i>
      <span>Recipes</span>
    <% end %>
    <%= link_to chats_path, class: "mobile-nav-item #{'active' if current_page?(chats_path)}" do %>
      <i class="fa-solid fa-comment"></i>
      <span>Chats</span>
    <% end %>
    <%= link_to profil_path(current_user.profil || current_user.create_profil(dietary_preferences: "")), class: "mobile-nav-item #{'active' if controller_name == 'profils'}" do %>
      <i class="fa-solid fa-user"></i>
      <span>Profile</span>
    <% end %>

  <% else %>

    <%= link_to new_user_session_path, class: "mobile-nav-item" do %>
      <i class="fa-solid fa-right-to-bracket"></i>
      <span>Login</span>
    <% end %>
    <%= link_to new_user_registration_path, class: "mobile-nav-item" do %>
      <i class="fa-solid fa-user-plus"></i>
      <span>Sign up</span>
    <% end %>

  <% end %>
</nav>
