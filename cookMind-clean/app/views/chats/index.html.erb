<div class="container mt-4 ingredients-page">

  <div class="text-center mb-4">
    <h1 class="fw-500">Your past conversations</h1>
  </div>

  <% if @chats.any? %>
    <% @chats.each do |chat| %>
      <%= link_to chat_path(chat), class: "chat-history-item d-flex justify-content-between align-items-center mb-2" do %>
        <span class="chat-history-title"><%= chat.title %></span>
        <span class="chat-history-date"><%= chat.created_at.strftime("%b %d, %Y") %></span>
      <% end %>
    <% end %>
  <% else %>
    <p class="text-muted text-center">No conversations yet.</p>
  <% end %>

</div>
